# AIOps Multi-Agent Demo — Environment Configuration Template
#
# 1. Copy to .env: `cp .env.example .env`
# 2. Replace <PLACEHOLDER> values with your actual values
# 3. NEVER commit .env to git (already in .gitignore)
# 4. bootstrap.sh / phase별 deploy.sh 가 자동 채움

# ============================================================
# AWS Configuration
# ============================================================
AWS_REGION=us-west-2
AWS_ACCOUNT_ID=<YOUR_AWS_ACCOUNT_ID>

# ============================================================
# Bedrock Models — per-agent (sample-deep-insight 패턴)
# ============================================================
MONITOR_MODEL_ID=global.anthropic.claude-sonnet-4-6
INCIDENT_MODEL_ID=global.anthropic.claude-sonnet-4-6
CHANGE_MODEL_ID=global.anthropic.claude-haiku-4-5-20251001-v1:0
SUPERVISOR_MODEL_ID=global.anthropic.claude-sonnet-4-6

# ============================================================
# DEMO_USER (multi-tenant prefix)
# ============================================================
# 동일 AWS 계정에 여러 시연자가 동시 배포할 때 충돌 방지용 식별자.
# CFN 스택 / KeyPair 이름 prefix 에 포함 (`aiops-demo-${DEMO_USER}-phase0-ec2` 등).
# 미설정 시 deploy.sh 가 OS user (`$USER`) 로 자동 fallback. 영문/숫자/하이픈만 권장 (≤16자).
DEMO_USER=

# ============================================================
# OpenTelemetry — CloudWatch GenAI Observability 자동 통합
# ============================================================
OTEL_PYTHON_DISTRO=aws_distro
OTEL_PYTHON_CONFIGURATOR=aws_configurator
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_EXPORTER_OTLP_LOGS_HEADERS=x-aws-log-group=aiops-demo-observability,x-aws-log-stream=spans,x-aws-metric-namespace=AIOpsDemo
AGENT_OBSERVABILITY_ENABLED=true
# OTEL_RESOURCE_ATTRIBUTES — 각 에이전트가 진입 시 service.name=monitor 등으로 override

# ============================================================
# GitHub (PAT는 SSM SecureString에 저장. 여기엔 경로만)
# ============================================================
GITHUB_REPO=<YOUR_GITHUB_USER>/aiops-demo-data
GITHUB_TOKEN_SSM_PATH=/aiops-demo/github-token

# ============================================================
# Cognito (Phase 2 deploy.sh가 자동 채움. Phase 4 에서 Client A/B 추가)
# ============================================================
COGNITO_USER_POOL_ID=
COGNITO_DOMAIN=
COGNITO_CLIENT_C_ID=
COGNITO_CLIENT_C_SECRET=
# 형식: aiops-demo-${DEMO_USER}-resource-server/invoke
COGNITO_GATEWAY_SCOPE=
# (Phase 4 에서 추가) COGNITO_CLIENT_A_ID / SECRET, COGNITO_CLIENT_B_ID / SECRET

# ============================================================
# Phase 0: EC2 Simulator (deploy.sh가 채움)
# ============================================================
EC2_INSTANCE_ID=
EC2_PUBLIC_IP=

# ============================================================
# Phase 2: AgentCore Gateway + Lambda ARNs (deploy.sh가 채움)
# ============================================================
GATEWAY_URL=
GATEWAY_ID=
LAMBDA_HISTORY_MOCK_ARN=
LAMBDA_CLOUDWATCH_WRAPPER_ARN=

# ============================================================
# Phase 3+: AgentCore Runtimes (phase별 deploy.sh 가 채움)
# ============================================================
MONITOR_RUNTIME_ARN=
MONITOR_RUNTIME_ID=
INCIDENT_RUNTIME_ARN=
INCIDENT_RUNTIME_ID=
CHANGE_RUNTIME_ARN=
CHANGE_RUNTIME_ID=
SUPERVISOR_RUNTIME_ARN=
SUPERVISOR_RUNTIME_ID=
