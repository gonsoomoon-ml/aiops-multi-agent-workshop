# ---- Bedrock ----
AWS_REGION=us-west-2
# Model ID for Strands Agent (Bedrock cross-region inference profile recommended)
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# ---- GitHub ----
# Personal Access Token with 'repo' scope
GITHUB_TOKEN=
# owner/repo form
GITHUB_REPO=your-user/noise-alarm-demo
GITHUB_BRANCH=main

# ---- Offline demo mode ----
# If set to '1', GitHub tool reads/writes local filesystem instead of remote repo.
# Useful for running Lab 1 without GitHub credentials.
OFFLINE_MODE=1

# ---- Bonus (real CloudWatch) ----
# Real AWS alarm to query in Bonus lab
BONUS_ALARM_NAME=demo-cpu-high

# ---- Gateway / Runtime (Lab 2+/3) ----
AGENTCORE_GATEWAY_ID=
AGENTCORE_RUNTIME_ID=
